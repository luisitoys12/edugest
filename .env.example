# EduGest - Variables de entorno
# Copia este archivo como .env y llena los valores reales

# Supabase (produccion)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Base de datos PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Servidor
NODE_ENV=development
PORT=5000

# GitHub Pages (para deploy estatico)
VITE_API_BASE_URL=https://luisitoys12.github.io/edugest
